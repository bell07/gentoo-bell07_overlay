PORTAGE_BINHOST="http://bell.7u.org/pub/gentoo-bben_mn9/packages/"


COMMON_CFLAGS="-O2 -march=silvermont -maes --param=l1-cache-line-size=64 --param=l1-cache-size=24 --param=l2-cache-size=1024 -fomit-frame-pointer -pipe"
CFLAGS="${COMMON_CFLAGS}"
CXXFLAGS="${COMMON_CFLAGS}"
FCFLAGS="${COMMON_CFLAGS}"
FFLAGS="${COMMON_CFLAGS}"

RUSTFLAGS=""

CPU_FLAGS_X86="aes mmx mmxext pclmul popcnt rdrand sse sse2 sse3 sse4_1 sse4_2 ssse3"

VIDEO_CARDS="intel i915"

